# ── LLM 配置 ──
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── 搜索 API ──
SEMANTIC_SCHOLAR_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# ── 服务配置 ──
HOST=0.0.0.0
PORT=8000

# ── 沙箱 ──
SANDBOX_ENABLED=false
SANDBOX_TIMEOUT=600
